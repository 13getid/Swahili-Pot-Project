PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/swahilipot_ims
JWT_SECRET=your_very_long_random_secret_here
CLIENT_URL=http://localhost:5173

# S3 storage for uploaded files
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET=swahilipot-ims-uploads
# Optional: only set for S3-compatible providers (Cloudflare R2, MinIO, ...)
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# SMTP for password-reset emails (optional).
# If unset, reset links are printed to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SwahiliPot IMS <no-reply@swahilipothub.co.ke>
